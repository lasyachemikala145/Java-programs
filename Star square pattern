package pattern;

import java.util.Scanner;

public class SquarePattern {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner sc=new Scanner(System.in);
		System.out.print("enter the n");
		int n=sc.nextInt();
		int i=1;
		int j=1;
		for(i=1;i<=n;i++) {
			for(j=1;j<=n;j++) {
				System.out.print("*");
				}
			System.out.println(" ");
			}
		}
			

	}


