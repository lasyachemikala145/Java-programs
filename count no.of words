package com.stringpractice;

import java.util.Scanner;

public class WordInReverse {

	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);
		String s=sc.nextLine();
		System.out.print(printCountWords(s));
		System.out.print(printCountWords1(s));
	}
	// method 1
	public static int printCountWords(String s) {
		int count=0;
		for(int i=1;i<s.length();i++) {
			if(s.charAt(i)!=' ' && s.charAt(i-1)==' ') {
				count++;
			}
		}
		return s.charAt(0)==' '?count:count+1;
	}
	// method 2
	int count1=0;
	public static int printCountWords1(String s) {
		int count1=0;
		for(int i=0;i<s.length()-1;i++) {
			if(s.charAt(i)!=' ' && s.charAt(i+1)==' ') {
				count1++;
			}
		}
		return s.charAt(s.length()-1)==' '?count1:count1+1;
	

}
}
